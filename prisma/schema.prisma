generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant: Every lender is an isolated tenant ───

model Lender {
  id              String         @id @default(uuid())
  name            String
  trial_ends_at   DateTime       @default(now()) // set properly in app code
  license_status  LicenseStatus  @default(trial)
  license_expires DateTime?      // null = no active paid license
  address         String?
  lat             Float?
  lng             Float?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  users         User[]
  borrowers     Borrower[]
  loans         Loan[]
  payments      Payment[]
  documents     Document[]
  schedules     PaymentSchedule[]
  subscriptions Subscription[]

  @@map("lenders")
}

enum LicenseStatus {
  trial
  active
  expired
  suspended
}

// ─── Platform Admin ───

model Admin {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  created_at DateTime @default(now())

  @@map("admins")
}

// ─── License Codes: generated by admin, redeemed by lenders ───

model LicenseCode {
  id           String          @id @default(uuid())
  code         String          @unique
  plan         LicensePlan
  duration_days Int            // actual days the license grants
  is_used      Boolean         @default(false)
  used_by      String?         // lender_id that redeemed it
  used_at      DateTime?
  created_at   DateTime        @default(now())

  @@map("license_codes")
}

enum LicensePlan {
  monthly      // 30 days
  quarterly    // 90 days
  semiannual   // 180 days
  yearly       // 365 days
}

// ─── Subscription history ───

model Subscription {
  id           String      @id @default(uuid())
  lender_id    String
  lender       Lender      @relation(fields: [lender_id], references: [id], onDelete: Cascade)
  plan         LicensePlan
  license_code String
  starts_at    DateTime
  ends_at      DateTime
  created_at   DateTime    @default(now())

  @@map("subscriptions")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String?
  name          String
  role          Role     @default(staff)
  lender_id     String
  lender        Lender   @relation(fields: [lender_id], references: [id], onDelete: Cascade)
  auth_provider String?  // "google", "facebook", or null for email/password
  provider_id   String?  // Google/Facebook user ID
  avatar_url    String?
  created_at    DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

enum Role {
  owner
  staff
}

model Borrower {
  id                  String   @id @default(uuid())
  lender_id           String
  lender              Lender   @relation(fields: [lender_id], references: [id], onDelete: Cascade)
  name                String
  phone               String
  registered_address  String
  registered_lat      Float?
  registered_lng      Float?
  residential_address String
  residential_lat     Float?
  residential_lng     Float?
  work_address        String?
  work_lat            Float?
  work_lng            Float?
  lat                 Float?   // primary/default pin (kept for backward compat)
  lng                 Float?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  loans     Loan[]
  documents Document[]

  @@map("borrowers")
}

model Loan {
  id                 String             @id @default(uuid())
  lender_id          String
  lender             Lender             @relation(fields: [lender_id], references: [id], onDelete: Cascade)
  borrower_id        String
  borrower           Borrower           @relation(fields: [borrower_id], references: [id], onDelete: Cascade)

  // Core loan terms
  principal          Float
  interest_rate      Float              // e.g. 5 means 5%
  interest_rate_unit InterestRateUnit   // daily, monthly, yearly
  interest_method    InterestMethod     @default(flat)
  term_length        Int
  term_unit          TermUnit           // days, months
  payment_frequency  PaymentFrequency   // daily, weekly, monthly
  interest_behavior  InterestBehavior   // simple, capitalize
  collateral         String?            // หลักประกัน

  // Computed at creation
  daily_rate         Float
  total_interest     Float
  total_payable      Float
  installment_count  Int
  installment_amount Float

  // Running balance
  outstanding_balance Float
  total_paid          Float             @default(0)

  status             LoanStatus         @default(active)
  disbursed_at       DateTime           @default(now())

  // Contract signatures (base64 data URLs)
  sig_lender         String?            @db.Text
  sig_borrower       String?            @db.Text
  sig_witness1       String?            @db.Text
  sig_witness2       String?            @db.Text
  witness1_name      String?
  witness2_name      String?

  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt

  schedules PaymentSchedule[]
  payments  Payment[]

  @@map("loans")
}

enum InterestRateUnit {
  daily
  monthly
  yearly
}

enum InterestMethod {
  flat
}

enum TermUnit {
  days
  months
}

enum PaymentFrequency {
  daily
  weekly
  monthly
}

enum InterestBehavior {
  simple
  capitalize
}

enum LoanStatus {
  active
  completed
  defaulted
}

model PaymentSchedule {
  id            String         @id @default(uuid())
  lender_id     String
  lender        Lender         @relation(fields: [lender_id], references: [id], onDelete: Cascade)
  loan_id       String
  loan          Loan           @relation(fields: [loan_id], references: [id], onDelete: Cascade)
  installment   Int            // 1, 2, 3...
  due_date      DateTime
  principal_due Float
  interest_due  Float
  total_due     Float
  principal_paid Float         @default(0)
  interest_paid  Float         @default(0)
  status        ScheduleStatus @default(pending)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  @@map("payment_schedules")
}

enum ScheduleStatus {
  pending
  paid
  partial
  overdue
}

model Payment {
  id             String      @id @default(uuid())
  lender_id      String
  lender         Lender      @relation(fields: [lender_id], references: [id], onDelete: Cascade)
  loan_id        String
  loan           Loan        @relation(fields: [loan_id], references: [id], onDelete: Cascade)
  schedule_id    String?
  amount         Float
  interest_paid  Float
  principal_paid Float
  payment_type   PaymentType @default(cash)
  slip_image     String?     // file path for bank transfer proof
  payment_date   DateTime    @default(now())
  notes          String?
  created_at     DateTime    @default(now())

  @@map("payments")
}

enum PaymentType {
  cash
  bank_transfer
}

model Document {
  id          String   @id @default(uuid())
  lender_id   String
  lender      Lender   @relation(fields: [lender_id], references: [id], onDelete: Cascade)
  borrower_id String
  borrower    Borrower @relation(fields: [borrower_id], references: [id], onDelete: Cascade)
  filename    String
  filepath    String
  mimetype    String
  size        Int
  created_at  DateTime @default(now())

  @@map("documents")
}
